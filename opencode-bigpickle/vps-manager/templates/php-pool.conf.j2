[{{ domain }}]
user = {{ user }}
group = {{ user }}
listen = /run/php/php{{ version }}-fpm-{{ domain }}.sock
listen.owner = {{ user }}
listen.group = {{ user }}
listen.mode = 0660
pm = ondemand
pm.max_children = 10
pm.process_idle_timeout = 30s
pm.max_requests = 500
chdir = /
security.limit_extensions = .php .php3 .php4 .php5 .phtml

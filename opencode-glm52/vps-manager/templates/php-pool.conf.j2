; {{ domain }} — PHP-FPM pool managed by vps-manager. Do not edit by hand.
; PHP version: {{ php_version }}

[{{ domain }}]
user = {{ user }}
group = {{ user }}

listen = {{ socket }}
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

; Chroot not used; site isolation is via SFTP chroot + unix user.
pm = dynamic
pm.max_children = 25
pm.start_servers = 3
pm.min_spare_servers = 2
pm.max_spare_servers = 5
pm.max_requests = 500

; Webroot for this site.
php_admin_value[doc_root] = {{ webroot }}
php_admin_value[upload_tmp_dir] = {{ webroot }}/../tmp
php_admin_value[session.save_path] = {{ webroot }}/../sessions

; Hardening: disable dangerous functions, prevent exec of arbitrary binaries.
php_admin_value[disable_functions] = exec,passthru,shell_exec,system,proc_open,popen,curl_multi_exec,parse_ini_file,show_source
php_admin_flag[allow_url_fopen] = off
php_admin_flag[allow_url_include] = off
php_admin_value[open_basedir] = {{ webroot }}:/home/{{ user }}/tmp:/home/{{ user }}/sessions:/tmp

; Logging per-pool.
php_admin_value[error_log] = /var/log/vpsmgr/php-{{ domain }}.log
php_admin_flag[log_errors] = on

# PHP-FPM Pool Configuration
# Variables: domain, php_version, sftp_user, php_version

[{{ domain }}]
; User and group for this pool
user = {{ sftp_user }}
group = www-data

; Unix socket for communication with web server
listen = /run/php/php{{ php_version }}-fpm.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

; Process pool manager settings
pm = dynamic
pm.max_children = 20
pm.start_servers = 5
pm.min_spare_servers = 5
pm.max_spare_servers = 10
pm.max_requests = 500
pm.status_path = /php-status

; Logging
slowlog = /var/log/php-fpm/{{ domain }}-slow.log
slowlog_timeout = 30s
request_slowlog_timeout = 30s
request_terminate_timeout = 300s

; Security and limits
security.limit_extensions = .php
catch_workers_output = yes
env[PATH] = /usr/local/bin:/usr/bin:/bin

; Memory and execution limits
php_value[memory_limit] = 256M
php_value[max_execution_time] = 300
php_value[max_input_time] = 300

; File upload limits
php_value[upload_max_filesize] = 256M
php_value[post_max_size] = 256M

; Session configuration
php_value[session.save_path] = /tmp
php_value[session.gc_maxlifetime] = 1440

; Opcache (opcode caching for performance)
php_value[opcache.enable] = 1
php_value[opcache.memory_consumption] = 128
php_value[opcache.interned_strings_buffer] = 8
php_value[opcache.max_accelerated_files] = 4000
php_value[opcache.validate_timestamps] = 1
php_value[opcache.revalidate_freq] = 60
php_value[opcache.save_comments] = 1
php_value[opcache.enable_file_override] = 1

; Error reporting
php_value[display_errors] = Off
php_value[display_startup_errors] = Off
php_value[error_reporting] = E_ALL & ~E_DEPRECATED & ~E_STRICT
php_value[log_errors] = On
php_value[error_log] = /var/log/php-fpm/{{ domain }}-error.log

; Security settings
php_value[expose_php] = Off
php_value[disable_functions] = proc_open,proc_close,proc_get_status,proc_nice,proc_terminate,exec,passthru,shell_exec,system
php_value[disable_classes] =

; Date and timezone
php_value[date.timezone] = UTC

; Default charset
php_value[default_charset] = UTF-8

; Extensions
php_value[extension_dir] = /usr/lib/php/{{ php_version }}/

; Allow environment variables
clear_env = no

; Pool: {{ domain }} — managed by vpsmgr
; Generated: {{ generated_at }}

[{{ sftp_user }}]
user = {{ sftp_user }}
group = {{ sftp_user }}

listen = /run/php/php{{ php_version }}-fpm-{{ sftp_user }}.sock
listen.owner = {{ fpm_user }}
listen.group = {{ fpm_group }}
listen.mode = 0660

; Process management
pm = ondemand
pm.max_children = {{ pm_max_children|default(10) }}
pm.process_idle_timeout = 30s
pm.max_requests = 500

; Resource limits
php_admin_value[memory_limit] = {{ memory_limit|default("256M") }}
php_admin_value[upload_max_filesize] = {{ upload_max_filesize|default("64M") }}
php_admin_value[post_max_size] = {{ post_max_size|default("64M") }}
php_admin_value[max_execution_time] = {{ max_execution_time|default(300) }}
php_admin_value[max_input_time] = {{ max_input_time|default(300) }}

; Path restrictions
php_admin_value[open_basedir] = {{ webroot }}:/tmp:/usr/share/php
php_admin_value[session.save_path] = {{ home_dir }}/tmp

; Security hardening
php_admin_value[disable_functions] = exec,passthru,shell_exec,system,proc_open,popen,curl_multi_exec,parse_ini_file,show_source
php_admin_value[allow_url_fopen] = On
php_admin_value[allow_url_include] = Off
php_admin_value[expose_php] = Off
php_admin_value[display_errors] = Off
php_admin_value[display_startup_errors] = Off

chdir = /